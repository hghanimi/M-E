# .gitignore
# ── Secrets — NEVER commit these ──────────────────
.env

# ── Python ────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# ── Pipeline output (local fallback only) ─────────
portfolio-data.json

# ── OS ────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Node / Vite ───────────────────────────────────
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
