# ============================================================
#  .env  —  NEVER commit this file to git / version control
#  Copy this file:  cp .env.example .env
#  Then fill in every value below.
# ============================================================

# ── OpenAI ───────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Supabase (server-side, service-role key) ─────────────────
# Find both values at: https://supabase.com/dashboard → your project → Settings → API
# SUPABASE_URL        : looks like  https://abcdefghij.supabase.co
# SUPABASE_SERVICE_KEY: the "service_role" secret key (NOT the anon key)
#   WARNING — the service key bypasses RLS.  Keep it server-side only.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Supabase Storage ─────────────────────────────────────────
# Name of the private bucket you created for raw M&E documents.
# Default matches the bucket name in schema.sql.
SUPABASE_STORAGE_BUCKET=raw-documents

# ── Watch mode ───────────────────────────────────────────────
# How often (in seconds) the pipeline checks for new files when
# run with  python pipeline.py --watch
# 300 = every 5 minutes
POLL_INTERVAL_SECS=300
