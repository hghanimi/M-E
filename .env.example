# ============================================================
#  .env  —  NEVER commit this file to git / version control
#  Copy this file:  cp .env.example .env
#  Then fill in every value below.
# ============================================================

# ── Supabase project values ──────────────────────────────────
# Set these for Vite React frontend and Supabase function calls.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...
VITE_SUPABASE_STORAGE_BUCKET=raw-documents

# Optional compatibility vars for older scripts/files still in repository.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_STORAGE_BUCKET=raw-documents

# IMPORTANT:
# Keep OPENAI_API_KEY and SUPABASE_SERVICE_ROLE_KEY in Supabase Edge Function
# secrets, not in frontend environment variables.
